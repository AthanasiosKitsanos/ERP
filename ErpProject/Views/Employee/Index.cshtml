@using ErpProject.Models.EmployeeProfile
@model List<Employee>

<div>
    <a asp-controller="Employee" asp-action="Register">Register new Employee</a>
</div>

@foreach(Employee employee in Model)
{
    <div>
        <ul style="list-style: none;">
            <li>
                @employee.FirstName
            </li>

            <li>
                <a asp-controller="EmploymentDetails" asp-action="Details" asp-route-id="@employee.Id">More details</a>
            </li>
        </ul>
    </div>
}