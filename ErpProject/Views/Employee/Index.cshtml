@using ErpProject.Models
@model List<Employee>

@section Styles
{
    <link rel="stylesheet" href="~/CSS/update.css" asp-append-version="true">
}

<div>

    <div>
        <a asp-action="Register">Register new Employee</a>
    </div>

    <div>
        <table>
            <thead>
                <tr>
                    <th>First Name</th>

                    <th>Last Name</th>

                    <th>Email</th>

                    <th>Age</th>

                    <th>Date of Birth</th>

                    <th>Nationality</th>

                    <th>Gender</th>

                    <th>Phone Number</th>

                    <th>Profile Photo</th>
                </tr>
            </thead>
            <tbody>
                @foreach(Employee employee in Model)
                {
                    <tr>
                        <td>@employee.FirstName</td>
                        <td>@employee.LastName</td>
                        <td>@employee.Email</td>
                        <td>@employee.Age</td>
                        <td>@employee.DateOfBirth.ToString("dd-MM-yyyy")</td>
                        <td>@employee.Nationality</td>
                        <td>@employee.Gender</td>
                        <td>@employee.PhoneNumber</td>
                        <td>
                            @if(employee.Photograph is not null)
                            {   
                                var base64 = Convert.ToBase64String(employee.Photograph);
                                var imageSrc = $"data:{employee.MIME};base64,{base64}";
                                <img src="@imageSrc" style="width: 100px; height: auto;">
                            }   
                            else
                            {
                                <span>No Photo</span>
                            }
                        </td>>
                        <td><a asp-action="Update" asp-route-id="@employee.Id">Edit</a></td>
                        <td><a asp-action="Delete" asp-route-id="@employee.Id">Delete</a></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>