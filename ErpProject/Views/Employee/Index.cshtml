@using ErpProject.Models.EmployeeProfile
@model List<Employee>

<div>
    <table>
        <thead>
            <tr>
                <th>First Name</th>

                <th>Last Name</th>

                <th>Email</th>

                <th>Age</th>

                <th>Date of Birth</th>

                <th>Nationality</th>

                <th>Gender</th>

                <th>Phone Number</th>
            </tr>
        </thead>
        <tbody>
            @foreach(Employee employee in Model)
            {
                <tr>
                    <td>@employee.FirstName</td>
                    <td>@employee.LastName</td>
                    <td>@employee.Email</td>
                    <td>@employee.Age</td>
                    <td>@employee.DateOfBirth.ToString("dd-MM-yyyy")</td>
                    <td>@employee.Nationality</td>
                    <td>@employee.Gender</td>
                    <td>@employee.PhoneNumber</td>
                    <td><a asp-controller="Employee" asp-action="Update" asp-route-id="@employee.Id">Edit</a></td>
                    <td><a asp-controller="Employee" asp-action="Details" asp-route-id="@employee.Id">Details</a></td>
                    <td>
                        <a asp-controller="Employee" asp-action="Delete" asp-route-id="@employee.Id">Delete</a>
                    </td>
                    
                </tr>
            }
        </tbody>
    </table>
</div>

<div>
    <a asp-controller="Employee" asp-action="Register">Register new Employee</a>
</div>