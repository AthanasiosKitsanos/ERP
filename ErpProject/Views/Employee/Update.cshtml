@using ErpProject.Models.EmployeeModel
@model Employee

<div>
    <form asp-action="UpdateEmployee" method="post">
        <ul style="list-style: none;">
            <li>
                <label>Email</label>
                <input type="text" asp-for="@Model.Email">
            </li>

            <li>
                <label>Phone Number</label>
                <input type="text" asp-for="@Model.PhoneNumber">
            </li>

            <li>
                <button type="submit">Update</button>
            </li>
        </ul>
    </form>
</div>