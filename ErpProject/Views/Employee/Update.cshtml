@using ErpProject.Models.DTOModels.Employee
@model UpdateDTO

<div>
    <form asp-controller="Employee" asp-action="Update" method="post">
        <ul style="list-style: none;">
            <li>
                <label>Email</label>
                <input type="text" asp-for="@Model.Email">
            </li>

            <li>
                <label>Phone Number</label>
                <input type="text" asp-for="@Model.PhoneNumber">
            </li>

            <li>
                <button type="submit">Update</button>
            </li>
        </ul>
    </form>
</div>