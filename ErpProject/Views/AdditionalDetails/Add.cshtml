@using ErpProject.Models.DTOModels
@model ViewModelDTO

@using(Html.BeginForm("AddDetails", "AdditionalDetails", FormMethod.Post, new {enctype = "multipart/form-data"}))
{
    @Html.AntiForgeryToken()

    <div>
        <ul>
            <li>
                <label>Emergency Number</label>
                <input type="text" asp-for="@Model.AdditionalDetails.EmergencyNumbers">
                <span asp-validation-for="@Model.AdditionalDetails.EmergencyNumbers"></span>
            </li>
            
            <li>
                <label>Education</label>
                <input type="text" asp-for="@Model.AdditionalDetails.Education">
                <span asp-validation-for="@Model.AdditionalDetails.Education"></span>
            </li>

            <li>
                <button type="submit">Next</button>
            </li>
        </ul>
    </div>
}