@using ErpProject.Models.DTOModels
@using ErpProject.Models.AccountStatusModel
@model ViewModelDTO

@using(Html.BeginForm("AddCredentials", "EmployeeCredentials", FormMethod.Post))
{
    <div>
        <ul>
            <li>
                <label>Username</label>
                <input asp-for="@Model.EmployeeCredential.Username">
                <span asp-validation-for="@Model.EmployeeCredential.Username"></span>
            </li>
                
            <li>
                <label>Password</label>
                <input asp-for="@Model.EmployeeCredential.Password">
                <span asp-validation-for="@Model.EmployeeCredential.Password"></span>
            </li>
                
            <li>
                <label>Confirm Password</label>
                <input asp-for="@Model.EmployeeCredential.ConfirmPassword">
                <span asp-validation-for="@Model.EmployeeCredential.ConfirmPassword"></span>
            </li>

            <li>
                <label>Acount Status</label>
                <select asp-for="@Model.AccountStatus.SelectedStatus">
                    @foreach(AccountStatus status in Model.AccountStatus.StatusList)
                    {
                        <option value="@status.Id">@status.StatusName</option>
                    }
                </select>
            </li>

            <li>
                <button type="submit">Complete Registration</button>
            </li>
        </ul>
    </div>
}