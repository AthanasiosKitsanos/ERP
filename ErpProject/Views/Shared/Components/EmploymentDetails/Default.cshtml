@using ErpProject.Models
@model EmploymentDetails

@section Styles
{
    <link rel="stylesheet" href="~/CSS/update.css" asp-append-version="true">
}

@{
    int id = Convert.ToInt32(ViewData["Id"]);
}

<div>
    <table>
        <tbody>
            <tr>
                <td><b>Position:</b></td>
                <td>@Model.Position</td>
            </tr>

            <tr>
                <td><b>Department:</b></td>
                <td>@Model.Department</td>
            </tr>
            
            <tr>
                <td><b>Employment Status</b></td>
                <td>@Model.EmploymentStatus</td>
            </tr>
            
            <tr>
                <td><b>Hire Date</b></td>
                @if(Model.HireDate == DateOnly.MinValue)
                {
                    <td></td>
                }
                else
                {
                    <td>@Model.HireDate.ToString("dd-MM-yyyy")</td>
                }
            </tr>

            <tr>
                <td><b>Contract Type</b></td>
                <td>@Model.ContractType</td>
            </tr>

            <tr>
                <td><b>Work Location</b></td>
                <td>@Model.WorkLocation</td>
            </tr>

            <tr>
                @if(string.IsNullOrEmpty(Model.Position) && string.IsNullOrWhiteSpace(Model.Position))
                {
                    <td><a asp-action="Add" asp-controller="EmploymentDetails" asp-route-id="@id">Add Details</a></td>
                }
                else
                {
                    <td><a asp-action="Update" asp-controller="EmploymentDetails" asp-route-id="@id">Edit</a></td>
                }
            </tr>
        </tbody>
    </table>
</div>